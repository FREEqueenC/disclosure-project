{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "YOUR_GKE_BACKEND_URL/api/$1" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
